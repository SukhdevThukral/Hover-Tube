{
    "name" : "Hover Tube",
    "description" : "wait wow",
    "version" : "0.1",
    "permissions" : [
        "storage",
        "tabs"
    ],
    "manifest_version" : 3,
    "background" : {
        "service_worker": "background.js",
        "type": "module"
    },
    "icons":{
        "16" : "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "content_scripts" : [
        {
            "matches" : ["<all_urls>"],
            "js" : ["gsap.min.js", "content.js"],
            "css" : ["hover.css"]
        }
    ],
    "host_permissions": ["https://www.googleapis.com/*", "https://www.youtube.com/*", "https://generativelanguage.googleapis.com/*"],
    "action" : {
        "default_icon" : "icon.png",
        "default_popup" : "hello.html"
    }
}