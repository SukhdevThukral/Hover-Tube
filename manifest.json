{
    "name" : "Hover Tube",
    "description" : "wait wow",
    "version" : "0.1",
    "manifest_version" : 3,
    "content_scripts" : [
        {
            "matches" : ["<all_urls>"],
            "js" : ["config.js", "content.js"],
            "css" : ["hover.css"]
        }
    ],
    "host_permissions": ["https://www.googleapis.com/*"],
    "action" : {
        "default_popup" : "hello.html"
    }
}